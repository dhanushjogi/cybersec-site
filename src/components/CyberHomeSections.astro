---
---

<!-- Who We Are + Core Capabilities Carousel -->
<>
  <section class="relative py-24 bg-[#020617] overflow-hidden">

    <!-- Background Glow -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
      <div class="absolute -top-[20%] -right-[10%] w-[50%] h-[50%] rounded-full bg-[#2563eb] opacity-[0.03] blur-[120px]"></div>
      <div class="absolute top-[40%] -left-[10%] w-[40%] h-[40%] rounded-full bg-[#008374] opacity-[0.03] blur-[100px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

        <!-- LEFT TEXT -->
        <div>

          <div class="flex items-center gap-4 mb-4">
            <span class="w-8 h-[2px] bg-[#60a5fa]"></span>
            <span class="text-[#60a5fa] font-semibold tracking-widest uppercase text-xs">Who We Are</span>
          </div>

          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">Proactive Cyber Defense &amp; Threat Management</h2>

          <div class="space-y-4 text-slate-400 leading-relaxed text-sm md:text-base">
            <p>At Cezentech, our journey began with a vision to revolutionize digital security and provide enterprise-grade protection to businesses worldwide.</p>
            <p>We operate at the forefront of cybersecurity by combining <strong>24/7 SOC monitoring, AI-driven incident response, and penetration testing</strong> to ensure your infrastructure remains secure against evolving threats.</p>
          </div>

          <div class="h-px w-full bg-gradient-to-r from-slate-800 to-transparent my-8"></div>

          <button class="px-8 py-3.5 bg-gradient-to-r from-[#2563eb] to-[#3b82f6] hover:from-[#3b82f6] hover:to-[#60a5fa] text-white font-semibold rounded transition-all shadow-[0_0_20px_rgba(37,99,235,0.4)] flex items-center gap-2 group">Read More →</button>

        </div>

        <!-- RIGHT IMAGE -->
        <div class="relative mt-12 lg:mt-0">

          <div class="relative z-10 w-4/5 ml-auto rounded-xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] border border-slate-800/50">
            <div class="absolute inset-0 bg-[#0f172a]/60 z-10"></div>
            <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31" class="w-full h-[350px] md:h-[450px] object-cover" />
          </div>

          <div class="absolute -bottom-12 md:-bottom-20 left-0 z-20 w-3/5 rounded-xl overflow-hidden border-[6px] border-[#020617] shadow-2xl">
            <img src="https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5" class="w-full h-[200px] md:h-[280px] object-cover" />
          </div>

        </div>

      </div>

    </div>

  </section>

  <section class="relative py-24 bg-[#020617] overflow-hidden border-t border-slate-800/50" id="capabilities">

    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#60a5fa 1px, transparent 1px); background-size: 24px 24px;"></div>
      <div class="absolute top-1/2 left-1/4 w-96 h-96 bg-[#2563eb] rounded-full mix-blend-screen filter blur-[150px] opacity-20 animate-pulse"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#008374] rounded-full mix-blend-screen filter blur-[150px] opacity-10"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

      <div class="flex flex-col md:flex-row justify-between items-end mb-12">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <span class="w-8 h-[2px] bg-[#60a5fa]"></span>
            <span class="text-[#60a5fa] font-semibold tracking-widest uppercase text-xs">Core Capabilities</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-white">Comprehensive <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#60a5fa] to-[#3b82f6]">Security Services</span></h2>
        </div>

        <div class="flex gap-3 mt-6 md:mt-0">
          <button id="carousel-prev" class="w-12 h-12 rounded-full border border-slate-700 bg-slate-800/50 text-white flex items-center justify-center hover:bg-[#2563eb] hover:border-[#2563eb] transition-all backdrop-blur-sm z-20 shadow-lg"><i class="fas fa-chevron-left"></i></button>
          <button id="carousel-next" class="w-12 h-12 rounded-full border border-slate-700 bg-slate-800/50 text-white flex items-center justify-center hover:bg-[#2563eb] hover:border-[#2563eb] transition-all backdrop-blur-sm z-20 shadow-lg"><i class="fas fa-chevron-right"></i></button>
        </div>
      </div>

      <div class="relative -mx-4 px-4">
        <div class="absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-[#020617] to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-[#020617] to-transparent z-10 pointer-events-none"></div>

        <div id="services-carousel" class="flex gap-6 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-12 pt-4 scroll-smooth">

          <div class="liquid-glass-card snap-start shrink-0 w-[300px] md:w-[380px] rounded-2xl p-8 cursor-pointer group flex flex-col justify-between">
            <div class="glass-glow"></div>
            <div class="glass-content h-full flex flex-col">
              <div>
                <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-blue-500/20 to-blue-600/10 border border-blue-500/30 flex items-center justify-center mb-6 text-blue-400 group-hover:scale-110 group-hover:text-blue-300 transition-all shadow-[0_0_15px_rgba(59,130,246,0.2)]">
                  <i class="fas fa-bullseye text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-white mb-3 font-poppins group-hover:text-[#60a5fa] transition-colors uppercase tracking-wider">SCOPE</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-6">In-depth analysis of your security needs</p>
              </div>
              <a href="#" class="inline-flex items-center gap-2 mt-auto text-sm font-medium text-[#60a5fa] hover:text-white transition-colors group-hover:gap-3">Learn more <i class="fas fa-arrow-right text-xs"></i></a>
            </div>
          </div>

          <div class="liquid-glass-card snap-start shrink-0 w-[300px] md:w-[380px] rounded-2xl p-8 cursor-pointer group flex flex-col justify-between">
            <div class="glass-glow"></div>
            <div class="glass-content h-full flex flex-col">
              <div>
                <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-purple-500/20 to-purple-600/10 border border-purple-500/30 flex items-center justify-center mb-6 text-purple-400 group-hover:scale-110 group-hover:text-purple-300 transition-all shadow-[0_0_15px_rgba(168,85,247,0.2)]">
                  <i class="fas fa-clipboard-list text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-white mb-3 font-poppins group-hover:text-[#60a5fa] transition-colors uppercase tracking-wider">ASSESS</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-6">Thorough evaluation of your current systems</p>
              </div>
              <a href="#" class="inline-flex items-center gap-2 mt-auto text-sm font-medium text-[#60a5fa] hover:text-white transition-colors group-hover:gap-3">Learn more <i class="fas fa-arrow-right text-xs"></i></a>
            </div>
          </div>

          <div class="liquid-glass-card snap-start shrink-0 w-[300px] md:w-[380px] rounded-2xl p-8 cursor-pointer group flex flex-col justify-between">
            <div class="glass-glow"></div>
            <div class="glass-content h-full flex flex-col">
              <div>
                <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-red-500/20 to-red-600/10 border border-red-500/30 flex items-center justify-center mb-6 text-red-400 group-hover:scale-110 group-hover:text-red-300 transition-all shadow-[0_0_15px_rgba(239,68,68,0.2)]">
                  <i class="fas fa-shield-virus text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-white mb-3 font-poppins group-hover:text-[#60a5fa] transition-colors uppercase tracking-wider">MITIGATE</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-6">Effective risk reduction strategies</p>
              </div>
              <a href="#" class="inline-flex items-center gap-2 mt-auto text-sm font-medium text-[#60a5fa] hover:text-white transition-colors group-hover:gap-3">Learn more <i class="fas fa-arrow-right text-xs"></i></a>
            </div>
          </div>

          <div class="liquid-glass-card snap-start shrink-0 w-[300px] md:w-[380px] rounded-2xl p-8 cursor-pointer group flex flex-col justify-between">
            <div class="glass-glow"></div>
            <div class="glass-content h-full flex flex-col">
              <div>
                <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-emerald-500/20 to-emerald-600/10 border border-emerald-500/30 flex items-center justify-center mb-6 text-emerald-400 group-hover:scale-110 group-hover:text-emerald-300 transition-all shadow-[0_0_15px_rgba(16,185,129,0.2)]">
                  <i class="fas fa-file-invoice text-2xl"></i>
                </div>
                <h3 class="text-xl font-bold text-white mb-3 font-poppins group-hover:text-[#60a5fa] transition-colors uppercase tracking-wider">AUDIT</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-6">Compliance verification and reporting</p>
              </div>
              <a href="#" class="inline-flex items-center gap-2 mt-auto text-sm font-medium text-[#60a5fa] hover:text-white transition-colors group-hover:gap-3">Learn more <i class="fas fa-arrow-right text-xs"></i></a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</>

<style is:global>
.hide-scrollbar::-webkit-scrollbar { display: none; }
.hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
.liquid-glass-card { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 4px 30px rgba(0,0,0,0.3), inset 0 0 0 1px rgba(255,255,255,0.05); transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), border-color 0.3s; position: relative; overflow: hidden; }
.liquid-glass-card::after { content: ''; position: absolute; top: 0; left: -150%; width: 50%; height: 100%; background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.1), transparent); transform: skewX(-25deg); transition: left 0.7s ease; pointer-events: none; }
.liquid-glass-card:hover { transform: translateY(-10px) scale(1.02); border-color: rgba(96, 165, 250, 0.4); z-index: 10; }
.liquid-glass-card:hover::after { left: 150%; }
.glass-glow { position: absolute; width: 250px; height: 250px; background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%); border-radius: 50%; pointer-events: none; opacity: 0; transition: opacity 0.3s ease; transform: translate(-50%, -50%); z-index: 0; }
.liquid-glass-card:hover .glass-glow { opacity: 1; }
.glass-content { position: relative; z-index: 1; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const carousel = document.getElementById('services-carousel') as HTMLElement | null;
  const prevBtn = document.getElementById('carousel-prev') as HTMLElement | null;
  const nextBtn = document.getElementById('carousel-next') as HTMLElement | null;
  
  if (carousel && prevBtn && nextBtn) {
    const getScrollAmount = (): number => {
      const card = carousel.querySelector('.liquid-glass-card') as HTMLElement | null;
      return card ? card.offsetWidth + 24 : 0;
    };
    
    const scrollLeft = (): void => {
      carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    };
    
    const scrollRight = (): void => {
      carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    };
    
    prevBtn.addEventListener('click', scrollLeft);
    nextBtn.addEventListener('click', scrollRight);
  }
  
  const cards = document.querySelectorAll('.liquid-glass-card') as NodeListOf<HTMLElement>;
  cards.forEach(card => {
    const glow = card.querySelector('.glass-glow') as HTMLElement | null;
    if (glow) {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        glow.style.left = `${x}px`;
        glow.style.top = `${y}px`;
      });
    }
  });
});
</script>
