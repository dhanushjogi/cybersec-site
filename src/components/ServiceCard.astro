---
export interface Props {
  title: string;
  description: string;
  icon: string;
  iconColor: string;
  shadowColor: string;
  href?: string;
}

const { title, description, icon, iconColor, shadowColor, href = '#' } = Astro.props;
---

<div class="liquid-glass-card snap-start shrink-0 w-[300px] md:w-[380px] rounded-2xl p-8 cursor-pointer group flex flex-col justify-between">
  <div class="glass-glow"></div>
  <div class="glass-content h-full flex flex-col">
    <div>
      <div class={`w-14 h-14 rounded-xl bg-gradient-to-br from-${iconColor}-500/20 to-${iconColor}-600/10 border border-${iconColor}-500/30 flex items-center justify-center mb-6 text-${iconColor}-400 group-hover:scale-110 group-hover:text-${iconColor}-300 transition-all shadow-[0_0_15px_rgba(${shadowColor},0.2)]`}>
        <i class={`fas fa-${icon} text-2xl`}></i>
      </div>
      <h3 class="text-xl font-bold text-white mb-3 font-poppins group-hover:text-[#60a5fa] transition-colors uppercase tracking-wider">{title}</h3>
      <p class="text-slate-400 text-sm leading-relaxed mb-6">{description}</p>
    </div>
    <a href={href} class="inline-flex items-center gap-2 mt-auto text-sm font-medium text-[#60a5fa] hover:text-white transition-colors group-hover:gap-3 aria-label={`Learn more about ${title}`}">
      Learn more <i class="fas fa-arrow-right text-xs"></i>
    </a>
  </div>
</div>

<style>
  .liquid-glass-card {
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s;
    position: relative;
    overflow: hidden;
  }

  .liquid-glass-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -150%;
    width: 50%;
    height: 100%;
    background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.1), transparent);
    transform: skewX(-25deg);
    transition: left 0.7s ease;
    pointer-events: none;
  }

  .liquid-glass-card:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: rgba(96, 165, 250, 0.4);
    z-index: 10;
  }

  .liquid-glass-card:hover::after {
    left: 150%;
  }

  .glass-glow {
    position: absolute;
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
    transform: translate(-50%, -50%);
    z-index: 0;
  }

  .liquid-glass-card:hover .glass-glow {
    opacity: 1;
  }

  .glass-content {
    position: relative;
    z-index: 1;
  }
</style>
