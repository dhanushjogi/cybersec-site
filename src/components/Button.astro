---
export type ButtonVariant = 'primary' | 'secondary' | 'outline';

export interface Props {
  href?: string;
  variant?: ButtonVariant;
  class?: string;
}

const { href, variant = 'primary', class: customClass = '' } = Astro.props;

const baseStyles = 'px-8 py-3 rounded-lg font-semibold transition-all shadow-lg flex items-center gap-2';

const variantStyles = {
  primary: 'bg-gradient-to-r from-[#2563eb] to-[#3b82f6] hover:from-[#3b82f6] hover:to-[#60a5fa] text-white shadow-[0_0_20px_rgba(37,99,235,0.4)]',
  secondary: 'bg-gradient-to-r from-[#60a5fa] to-[#3b82f6] hover:from-[#3b82f6] hover:to-[#2563eb] text-white shadow-[0_0_20px_rgba(96,165,250,0.4)]',
  outline: 'border-2 border-[#2563eb] text-[#60a5fa] hover:bg-[#2563eb]/10',
};

const classes = `${baseStyles} ${variantStyles[variant]} ${customClass}`;
const Element = href ? 'a' : 'button';
---

<Element {href} class={classes}>
  <slot />
</Element>

<style>
  a, button {
    cursor: pointer;
  }

  button {
    border: none;
    font-family: inherit;
  }
</style>
