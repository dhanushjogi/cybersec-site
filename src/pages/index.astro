---
import Layout from '../layouts/layout.astro';
import CyberHomeSections from '../components/CyberHomeSections.astro';
---

<Layout title="Cybersecurity Solutions">
  <main class="bg-[#020617] text-white min-h-screen selection:bg-cyan-500/30">
    <!-- Hero Section with refined spacing and alignment -->
    <section class="relative w-full h-screen overflow-hidden flex items-center justify-center">
      <!-- Data Rain Canvas -->
      <canvas id="dataRain" class="absolute inset-0 w-full h-full z-0 opacity-40"></canvas>
      
      <!-- Hero Content: Professionally aligned and spaced -->
      <div class="hero-content relative z-10 flex flex-col items-center justify-center text-center px-6 max-w-5xl mx-auto">
        <!-- Main Heading: High visual impact typography -->
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black text-white mb-8 tracking-tight leading-none drop-shadow-2xl">
          Complete <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Cybersecurity</span> Solutions
        </h1>
        
        <!-- Subheading with improved vertical rhythm -->
        <p class="text-slate-300 text-lg sm:text-xl md:text-2xl max-w-3xl mb-12 leading-relaxed font-medium">
          Protecting enterprises with 24/7 SOC monitoring, automated incident response, and advanced penetration testing.
        </p>
        
        <!-- CTAs: Polished button variants -->
        <div class="flex flex-col sm:flex-row gap-6 mb-16">
          <a 
            href="/industries"
            class="px-10 py-4.5 bg-cyan-600 hover:bg-cyan-500 text-white font-bold rounded-xl transition-all duration-300 shadow-[0_0_25px_rgba(6,182,212,0.3)] hover:shadow-[0_0_35px_rgba(6,182,212,0.5)] hover:-translate-y-0.5 flex items-center justify-center"
          >
            Explore Solutions
          </a>
          <a 
            href="/partners"
            class="px-10 py-4.5 border-2 border-slate-700 text-white hover:border-cyan-500 hover:text-cyan-400 font-bold rounded-xl transition-all duration-300 backdrop-blur-sm flex items-center justify-center"
          >
            Technology Partners
          </a>
        </div>
      </div>
      
      <!-- Scroll Indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </section>

    <!-- Content Sections -->
    <CyberHomeSections />

    <!-- Recommendation Section: Redesigned for production polish -->
    <section class="max-w-7xl mx-auto px-6 py-32">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
          Solution <span class="text-cyan-400">Recommendation</span> Engine
        </h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Tailored cybersecurity stacks based on your industry and infrastructure requirements.
        </p>
      </div>
      
      <div class="bg-slate-900/50 border border-slate-800 rounded-3xl p-8 md:p-12 backdrop-blur-xl shadow-2xl">
        <!-- Responsive grid for select controls -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
          <div class="space-y-3">
            <label class="block text-sm font-bold text-slate-400 uppercase tracking-widest ml-1">Industry</label>
            <select 
              id="industry-select"
              class="w-full bg-slate-800/50 border-2 border-slate-700 rounded-2xl px-5 py-4 text-white font-semibold focus:border-cyan-500 focus:ring-0 transition-all cursor-pointer hover:border-slate-600 appearance-none shadow-inner"
            >
              <option value="">Choose Industry</option>
              <option value="manufacturing">Manufacturing</option>
              <option value="healthcare">Healthcare</option>
            </select>
          </div>
          
          <div class="space-y-3">
            <label class="block text-sm font-bold text-slate-400 uppercase tracking-widest ml-1">Infrastructure</label>
            <select 
              id="infra-select"
              class="w-full bg-slate-800/50 border-2 border-slate-700 rounded-2xl px-5 py-4 text-white font-semibold focus:border-cyan-500 focus:ring-0 transition-all cursor-pointer hover:border-slate-600 appearance-none shadow-inner"
            >
              <option value="">Choose Infrastructure</option>
              <option value="sme">SME</option>
              <option value="enterprise">Enterprise</option>
              <option value="cloud">Cloud Native</option>
              <option value="hybrid">Hybrid</option>
            </select>
          </div>
          
          <div class="space-y-3">
            <label class="block text-sm font-bold text-slate-400 uppercase tracking-widest ml-1">Priority</label>
            <select 
              id="security-select"
              class="w-full bg-slate-800/50 border-2 border-slate-700 rounded-2xl px-5 py-4 text-white font-semibold focus:border-cyan-500 focus:ring-0 transition-all cursor-pointer hover:border-slate-600 appearance-none shadow-inner"
            >
              <option value="">Choose Requirement</option>
              <option value="dlp">Data Protection (DLP)</option>
              <option value="edr">Endpoint Security (EDR)</option>
              <option value="vuln">Vulnerability Mgmt</option>
              <option value="pam">Identity Security (PAM)</option>
            </select>
          </div>
        </div>

        <!-- Recommendation Output Card -->
        <div 
          id="global-recommendation"
          class="bg-cyan-500/5 border border-cyan-500/20 rounded-2xl p-8 text-slate-300 text-center text-xl font-medium min-h-[100px] flex items-center justify-center transition-all duration-500"
        >
          Select your requirements above to generate a custom security stack.
        </div>
        
        <!-- Interactive OEM Grid -->
        <div id="security-stack" class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 opacity-80 hover:opacity-100 transition-opacity">
          <!-- Forcepoint -->
          <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-6 hover:border-cyan-500/30 transition-all group">
            <div class="h-10 mb-4 flex items-center">
              <span class="text-cyan-400 font-bold tracking-tighter text-2xl group-hover:text-cyan-300 transition-colors">FORCEPOINT</span>
            </div>
            <p class="text-sm text-slate-400 font-medium uppercase tracking-wide">Data Protection</p>
          </div>
          <!-- SentinelOne -->
          <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-6 hover:border-cyan-500/30 transition-all group">
            <div class="h-10 mb-4 flex items-center">
              <span class="text-cyan-400 font-bold tracking-tighter text-2xl group-hover:text-cyan-300 transition-colors">SENTINELONE</span>
            </div>
            <p class="text-sm text-slate-400 font-medium uppercase tracking-wide">Endpoint Security</p>
          </div>
          <!-- Tenable -->
          <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-6 hover:border-cyan-500/30 transition-all group">
            <div class="h-10 mb-4 flex items-center">
              <span class="text-cyan-400 font-bold tracking-tighter text-2xl group-hover:text-cyan-300 transition-colors">TENABLE</span>
            </div>
            <p class="text-sm text-slate-400 font-medium uppercase tracking-wide">Vulnerability Mgmt</p>
          </div>
          <!-- ARCON -->
          <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-6 hover:border-cyan-500/30 transition-all group">
            <div class="h-10 mb-4 flex items-center">
              <span class="text-cyan-400 font-bold tracking-tighter text-2xl group-hover:text-cyan-300 transition-colors">ARCON</span>
            </div>
            <p class="text-sm text-slate-400 font-medium uppercase tracking-wide">Privileged Access</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  // Recommendation Engine Logic
  const selects = ['industry-select', 'infra-select', 'security-select'];
  const elements = selects.map(id => document.getElementById(id) as HTMLSelectElement);
  const resultBox = document.getElementById("global-recommendation");

  function update() {
    if (!resultBox || elements.some(el => !el)) return;
    
    const [ind, inf, sec] = elements.map(el => el.value);
    
    if (!ind || !inf || !sec) {
      resultBox.textContent = "Complete all fields to view your recommended security architecture.";
      resultBox.classList.replace('text-cyan-400', 'text-slate-300');
      return;
    }

    const stacks: Record<string, string> = {
      'manufacturing-dlp': 'Critical Infrastructure Stack: Forcepoint Enterprise DLP',
      'manufacturing-edr': 'Operational Tech Stack: SentinelOne XDR + Singularity Ranger',
      'healthcare-dlp': 'Compliance Stack: Forcepoint DLP + Healthcare Data Shield',
      'healthcare-edr': 'Medical Device Stack: SentinelOne Endpoint Security',
      'cloud-vuln': 'Cloud Native Stack: Tenable.io Vulnerability Management',
      'enterprise-pam': 'High Assurance Stack: ARCON Privileged Access Management'
    };

    const key = `${ind}-${sec}`;
    resultBox.textContent = stacks[key] || "Recommended Multi-Layer Defense: Trellix Security Platform";
    resultBox.classList.replace('text-slate-300', 'text-cyan-400');
    resultBox.classList.add('scale-[1.02]');
    setTimeout(() => resultBox.classList.remove('scale-[1.02]'), 200);
  }

  elements.forEach(el => el?.addEventListener('change', update));
</script>

<script>
  // Matrix Data Rain Animation - Polished Implementation
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('dataRain') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const resize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    window.addEventListener('resize', resize);
    resize();

    const chars = '01ｱｲｳｴｵｶｷｸｹｺｻｼｽｾｿﾀﾁﾂﾃﾄﾅﾆﾇネノﾊﾋﾌﾍﾎﾏﾐﾑメモヤユヨラリルレロワヲン';
    const fontSize = 16;
    const columns = Math.floor(canvas.width / fontSize);
    const drops = Array(columns).fill(1);

    function draw() {
      if (!ctx || !canvas) return;
      ctx.fillStyle = 'rgba(2, 6, 23, 0.15)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = `${fontSize}px monospace`;
      
      for (let i = 0; i < drops.length; i++) {
        const text = chars[Math.floor(Math.random() * chars.length)];
        
        // Dynamic color based on position
        const yPos = drops[i] * fontSize;
        ctx.fillStyle = yPos < 200 ? '#06b6d4' : '#0891b2';
        
        ctx.fillText(text, i * fontSize, yPos);

        if (yPos > canvas.height && Math.random() > 0.975) {
          drops[i] = 0;
        }
        drops[i]++;
      }
    }
    setInterval(draw, 50);
  });
</script>
