---
import Layout from '../../layouts/layout.astro';
---

<Layout title="Manufacturing Security Solutions">

<main class="bg-gray-900 text-white min-h-screen">

<section class="max-w-6xl mx-auto px-4 py-24 text-center">

<h1 class="text-4xl md:text-5xl font-bold text-blue-400">
Manufacturing Cybersecurity Solutions
</h1>
<div class="mt-10 flex justify-center gap-4 flex-wrap">

<button class="px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg hover:border-blue-400 transition">
SME
</button>

<button class="px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg hover:border-blue-400 transition">
Enterprise
</button>

<button class="px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg hover:border-blue-400 transition">
Cloud
</button>

<button class="px-4 py-2 bg-gray-800 border border-gray-700 rounded-lg hover:border-blue-400 transition">
Hybrid
</button>

</div>

<p class="mt-4 text-gray-300 max-w-2xl mx-auto">
Manufacturing environments require protection for operational technology,
industrial control systems, and sensitive production data.
</p>

</section>
<section class="max-w-6xl mx-auto px-4 pb-24">

<h2 class="text-3xl font-bold text-blue-400 mb-8 text-center">
Recommended OEM Vendors
</h2>

<div class="grid gap-6 md:grid-cols-3">

<!-- Forcepoint -->

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-xl font-semibold text-blue-300">Forcepoint</h3>
<p class="mt-2 text-gray-300 text-sm">
Provides Data Loss Prevention (DLP) and insider threat protection to safeguard sensitive manufacturing data and intellectual property.
</p>
</div>

<!-- Trellix -->

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-xl font-semibold text-blue-300">Trellix</h3>
<p class="mt-2 text-gray-300 text-sm">
Offers advanced endpoint security, threat detection, and extended detection & response for enterprise manufacturing environments.
</p>
</div>

<!-- SentinelOne -->

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-xl font-semibold text-blue-300">SentinelOne</h3>
<p class="mt-2 text-gray-300 text-sm">
AI-powered Endpoint Detection & Response (EDR) platform designed to protect endpoints across industrial networks.
</p>
</div>

<!-- Tenable -->

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-xl font-semibold text-blue-300">Tenable</h3>
<p class="mt-2 text-gray-300 text-sm">
Industry-leading vulnerability management platform that helps organizations identify and remediate security weaknesses.
</p>
</div>

<!-- ARCON -->

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-xl font-semibold text-blue-300">ARCON</h3>
<p class="mt-2 text-gray-300 text-sm">
Privileged Access Management (PAM) solution designed to protect critical systems and administrative accounts.
</p>
</div>

</div>

</section>
<section class="max-w-6xl mx-auto px-4 pb-24">

<h2 class="text-3xl font-bold text-blue-400 mb-8 text-center">
Security Domain → OEM Vendor Mapping
</h2>

<div class="grid gap-6 md:grid-cols-2">

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">Data Loss Prevention (DLP)</h3>
<p class="text-sm text-gray-300 mt-2">
Recommended Vendor: Forcepoint
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">Endpoint Detection & Response</h3>
<p class="text-sm text-gray-300 mt-2">
Recommended Vendors: SentinelOne / Trellix
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">Vulnerability Management</h3>
<p class="text-sm text-gray-300 mt-2">
Recommended Vendor: Tenable
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">Privileged Access Management</h3>
<p class="text-sm text-gray-300 mt-2">
Recommended Vendor: ARCON
</p>
</div>

</div>

</section>
<section class="max-w-6xl mx-auto px-4 pb-24">

<h2 class="text-3xl font-bold text-blue-400 mb-8 text-center">
Recommended Products & Solutions
</h2>

<div class="grid gap-6 md:grid-cols-2">

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">Forcepoint</h3>
<p class="text-sm text-gray-300 mt-2">
Product: Forcepoint DLP
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">SentinelOne</h3>
<p class="text-sm text-gray-300 mt-2">
Product: Singularity XDR Platform
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">Trellix</h3>
<p class="text-sm text-gray-300 mt-2">
Product: Trellix Endpoint Security (EDR)
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">Tenable</h3>
<p class="text-sm text-gray-300 mt-2">
Product: Tenable Nessus / Tenable.io
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">ARCON</h3>
<p class="text-sm text-gray-300 mt-2">
Product: ARCON Privileged Access Management (PAM)
</p>
</div>

</div>

</section>
<section class="max-w-6xl mx-auto px-4 pb-24">

<h2 class="text-3xl font-bold text-blue-400 mb-10 text-center">
Manufacturing Security Architecture
</h2>

<div class="space-y-6">

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">
Layer 1 — Data Protection
</h3>
<p class="text-sm text-gray-300 mt-2">
Prevent sensitive manufacturing data leakage and protect intellectual property.
</p>
<p class="text-sm text-gray-400 mt-2">
OEM Solution: Forcepoint DLP
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">
Layer 2 — Endpoint Security
</h3>
<p class="text-sm text-gray-300 mt-2">
Detect and respond to malware and advanced threats across endpoints and industrial systems.
</p>
<p class="text-sm text-gray-400 mt-2">
OEM Solutions: SentinelOne / Trellix EDR
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">
Layer 3 — Vulnerability Management
</h3>
<p class="text-sm text-gray-300 mt-2">
Continuously identify vulnerabilities in industrial infrastructure and network devices.
</p>
<p class="text-sm text-gray-400 mt-2">
OEM Solution: Tenable Nessus
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">
Layer 4 — Privileged Access Security
</h3>
<p class="text-sm text-gray-300 mt-2">
Secure privileged accounts that control industrial systems and production environments.
</p>
<p class="text-sm text-gray-400 mt-2">
OEM Solution: ARCON PAM
</p>
</div>

</div>

</section>
<section class="max-w-6xl mx-auto px-4 pb-24">
  <h2 class="text-3xl font-bold text-blue-400 mb-8 text-center">
    Quick OEM Recommendation
  </h2>

<label for="infra-type" class="block text-sm text-gray-300 mb-3">
Select Infrastructure Type
</label>

<select
id="infra-type"
class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 text-white mb-6"
>

<option value="">Choose infrastructure</option>
<option value="sme">SME</option>
<option value="enterprise">Enterprise</option>
<option value="cloud">Cloud</option>
<option value="hybrid">Hybrid</option>

</select>

  <div class="max-w-2xl mx-auto bg-gray-800 border border-gray-700 rounded-xl p-6">
    <label for="security-domain" class="block text-sm text-gray-300 mb-3">
      Select a security requirement
    </label>

    <select
      id="security-domain"
      class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 text-white"
    >
      <option value="">Choose a security domain</option>
      <option value="dlp">Data Loss Prevention</option>
      <option value="edr">Endpoint Detection & Response</option>
      <option value="vuln">Vulnerability Management</option>
      <option value="pam">Privileged Access Management</option>
    </select>

    <div id="recommendation-box" class="mt-6 bg-gray-900 border border-gray-700 rounded-lg p-4 text-gray-300">
      Select a security requirement to view the recommended OEM vendor.
    </div>
  </div>
</section>

<section class="max-w-6xl mx-auto px-4 pb-24">

<h2 class="text-3xl font-bold text-blue-400 mb-10 text-center">
Manufacturing Security Architecture
</h2>

<div class="grid gap-6">

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">
Identity & Access Layer
</h3>
<p class="text-sm text-gray-300 mt-2">
Control privileged access to critical systems and industrial control environments.
</p>
<p class="text-sm text-gray-400 mt-2">
OEM Solution: ARCON PAM
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">
Endpoint Protection Layer
</h3>
<p class="text-sm text-gray-300 mt-2">
Detect and respond to threats targeting manufacturing endpoints and production systems.
</p>
<p class="text-sm text-gray-400 mt-2">
OEM Solutions: SentinelOne / Trellix
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">
Data Protection Layer
</h3>
<p class="text-sm text-gray-300 mt-2">
Prevent leakage of sensitive production data and intellectual property.
</p>
<p class="text-sm text-gray-400 mt-2">
OEM Solution: Forcepoint DLP
</p>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6">
<h3 class="text-lg font-semibold text-blue-300">
Infrastructure Security Layer
</h3>
<p class="text-sm text-gray-300 mt-2">
Continuously identify vulnerabilities in servers, networks, and industrial infrastructure.
</p>
<p class="text-sm text-gray-400 mt-2">
OEM Solution: Tenable
</p>
</div>

</div>

</section>

<section class="max-w-4xl mx-auto px-4 pb-24">

<h2 class="text-3xl font-bold text-blue-400 mb-12 text-center">
Defense-in-Depth Architecture
</h2>

<div class="flex flex-col items-center space-y-4">

<div class="bg-blue-600 text-white px-6 py-3 rounded-lg">
Users / Operators
</div>

<div class="text-gray-500">↓</div>

<div class="bg-gray-800 border border-gray-700 px-6 py-4 rounded-lg text-center">
Identity Security
<p class="text-sm text-gray-400">ARCON PAM</p>
</div>

<div class="text-gray-500">↓</div>

<div class="bg-gray-800 border border-gray-700 px-6 py-4 rounded-lg text-center">
Endpoint Protection
<p class="text-sm text-gray-400">SentinelOne / Trellix</p>
</div>

<div class="text-gray-500">↓</div>

<div class="bg-gray-800 border border-gray-700 px-6 py-4 rounded-lg text-center">
Data Protection
<p class="text-sm text-gray-400">Forcepoint DLP</p>
</div>

<div class="text-gray-500">↓</div>

<div class="bg-gray-800 border border-gray-700 px-6 py-4 rounded-lg text-center">
Infrastructure Security
<p class="text-sm text-gray-400">Tenable Vulnerability Management</p>
</div>

</div>

</section>

<script>

const securityDomain = document.getElementById('security-domain');
const infraType = document.getElementById('infra-type');
const recommendationBox = document.getElementById('recommendation-box');

function updateRecommendation() {

  const domain = securityDomain.value;
  const infra = infraType.value;

  if (!domain || !infra) {
    recommendationBox.textContent =
      "Select both infrastructure type and security requirement to view recommendations.";
    return;
  }

  const mapping = {

    "sme-dlp": "Forcepoint → Forcepoint DLP",
    "enterprise-dlp": "Forcepoint → Forcepoint DLP",

    "sme-edr": "SentinelOne → Singularity XDR",
    "enterprise-edr": "SentinelOne / Trellix → Enterprise EDR",

    "cloud-vuln": "Tenable → Tenable.io Vulnerability Management",
    "enterprise-vuln": "Tenable → Nessus / Tenable Security Center",

    "hybrid-pam": "ARCON → ARCON Privileged Access Management",
    "enterprise-pam": "ARCON → Enterprise PAM Suite"

  };

  const key = `${infra}-${domain}`;

  recommendationBox.textContent =
    mapping[key] || "Recommended OEM: Trellix (Threat Detection & Monitoring)";

}

securityDomain.addEventListener("change", updateRecommendation);
infraType.addEventListener("change", updateRecommendation);

</script>

</main>

</Layout>