---
import Layout from '../layouts/layout.astro';
---

<Layout title="Technology Partners">

<main class="bg-gray-900 text-white min-h-screen">

<section class="max-w-6xl mx-auto px-4 py-24 text-center">

<h1 class="text-4xl md:text-5xl font-bold text-blue-400">
Technology Partners
</h1>

<p class="mt-4 text-gray-300 max-w-2xl mx-auto">
We collaborate with leading cybersecurity vendors to deliver enterprise-grade security solutions.
</p>

</section>

<section class="max-w-6xl mx-auto px-4 pb-24 grid gap-6 md:grid-cols-3">

<!-- SentinelOne -->

<a href="/partners/sentinelone">

<div class="bg-gray-800 border border-gray-700 rounded-xl p-6 hover:border-blue-400 hover:scale-105 transition">

<div class="mb-4 w-full flex items-center justify-center">
  <img src="/logos/sentinelone.png" class="h-14" alt="SentinelOne">
</div>

<h2 class="text-xl font-semibold text-blue-300">
SentinelOne
</h2>

<p class="mt-2 text-sm text-gray-300">
AI-powered Endpoint Detection & Response platform protecting endpoints, servers, and cloud workloads.
</p>

</div>

</a>

<!-- Forcepoint -->

<a href="/partners/forcepoint">

<div class="bg-gradient-to-r from-white/20 to-white/10 border border-gray-700 rounded-xl p-6 hover:border-blue-400 hover:scale-105 transition">

<div class="mb-4 w-full flex items-center justify-center">
  <img src="/logos/forcepoint.png" class="h-14" alt="Forcepoint">
</div>

<h2 class="text-xl font-semibold text-blue-300">
Forcepoint
</h2>

<p class="mt-2 text-sm text-gray-300">
Industry leader in Data Loss Prevention and insider threat protection.
</p>

</div>

</a>

<!-- Trellix -->

<a href="/partners/trellix">

<div class="bg-gradient-to-r from-white/20 to-white/10 border border-gray-700 rounded-xl p-6 hover:border-blue-400 hover:scale-105 transition">

<div class="mb-4 w-full flex items-center justify-center">
  <img src="/logos/trellix.png" class="h-14" alt="Trellix">
</div>

<h2 class="text-xl font-semibold text-blue-300">
Trellix
</h2>

<p class="mt-2 text-sm text-gray-300">
Advanced threat detection platform combining endpoint security and threat intelligence.
</p>

</div>

</a>

<!-- Tenable -->

<a href="/partners/tenable">

<div class="bg-gradient-to-r from-white/20 to-white/10 border border-gray-700 rounded-xl p-6 hover:border-blue-400 hover:scale-105 transition">

<div class="mb-4 w-full flex items-center justify-center">
  <img src="/logos/tenable.png" class="h-10" alt="Tenable">
</div>

<h2 class="text-xl font-semibold text-blue-300">
Tenable
</h2>

<p class="mt-2 text-sm text-gray-300">
Leading vulnerability management platform helping organizations identify security weaknesses.
</p>

</div>

</a>

<!-- ARCON -->

<a href="/partners/arcon">

<div class="bg-gradient-to-r from-white/20 to-white/10 border border-gray-700 rounded-xl p-6 hover:border-blue-400 hover:scale-105 transition">

<div class="mb-4 w-full flex items-center justify-center">
  <img src="/logos/arcon.png" class="h-14" alt="ARCON">
</div>

<h2 class="text-xl font-semibold text-blue-300">
ARCON
</h2>

<p class="mt-2 text-sm text-gray-300">
Privileged Access Management platform securing critical infrastructure and administrative access.
</p>

</div>

</a>

</section>

</main>

</Layout>