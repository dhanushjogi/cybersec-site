---
import Layout from '../layouts/layout.astro';
---

<Layout title="Services">

<main class="bg-gray-900 text-white min-h-screen">
  <!-- Hero Section -->
  <section class="max-w-6xl mx-auto px-4 py-24 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-blue-400">
      Our Cybersecurity Services
    </h1>
    <p class="mt-4 text-lg text-gray-300 max-w-2xl mx-auto">
      Cezen Tech provides comprehensive cybersecurity solutions to protect your business from evolving threats. From proactive assessments to 24/7 monitoring, we ensure your digital assets remain secure.
    </p>
  </section>

  <!-- Services Grid -->
  <section class="max-w-6xl mx-auto px-4 pb-24">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <!-- Penetration Testing -->
      <div class="bg-gray-800/70 border border-gray-700 rounded-xl p-6 hover:bg-gray-800/90 transition-colors">
        <h2 class="text-xl font-semibold text-blue-300 mb-3">Penetration Testing</h2>
        <p class="text-sm text-gray-300 mb-4">
          Comprehensive security testing including web applications, networks, APIs, and cloud infrastructure. We simulate real-world attacks to identify vulnerabilities before malicious actors can exploit them.
        </p>
        <ul class="text-xs text-gray-400 space-y-1">
          <li>• Web & Mobile App Testing</li>
          <li>• Network Penetration Testing</li>
          <li>• API Security Assessment</li>
          <li>• Detailed Remediation Reports</li>
        </ul>
      </div>

      <!-- Vulnerability Assessment -->
      <div class="bg-gray-800/70 border border-gray-700 rounded-xl p-6 hover:bg-gray-800/90 transition-colors">
        <h2 class="text-xl font-semibold text-blue-300 mb-3">Vulnerability Assessment</h2>
        <p class="text-sm text-gray-300 mb-4">
          Automated and manual scanning to identify security weaknesses across your entire IT infrastructure. Regular assessments help maintain a strong security posture.
        </p>
        <ul class="text-xs text-gray-400 space-y-1">
          <li>• Automated Vulnerability Scanning</li>
          <li>• Manual Verification</li>
          <li>• Risk Prioritization</li>
          <li>• Compliance Reporting</li>
        </ul>
      </div>

      <!-- SOC as a Service -->
      <div class="bg-gray-800/70 border border-gray-700 rounded-xl p-6 hover:bg-gray-800/90 transition-colors">
        <h2 class="text-xl font-semibold text-blue-300 mb-3">SOC as a Service</h2>
        <p class="text-sm text-gray-300 mb-4">
          24/7 Security Operations Center monitoring using advanced SIEM tools. Our expert analysts detect, investigate, and respond to security incidents in real-time.
        </p>
        <ul class="text-xs text-gray-400 space-y-1">
          <li>• 24/7 Threat Monitoring</li>
          <li>• SIEM Implementation</li>
          <li>• Alert Triage & Response</li>
          <li>• Threat Intelligence</li>
        </ul>
      </div>

      <!-- Incident Response -->
      <div class="bg-gray-800/70 border border-gray-700 rounded-xl p-6 hover:bg-gray-800/90 transition-colors">
        <h2 class="text-xl font-semibold text-blue-300 mb-3">Incident Response</h2>
        <p class="text-sm text-gray-300 mb-4">
          Rapid response to security breaches with containment, eradication, and recovery strategies. Minimize damage and learn from incidents to prevent future occurrences.
        </p>
        <ul class="text-xs text-gray-400 space-y-1">
          <li>• Breach Containment</li>
          <li>• Digital Forensics</li>
          <li>• Root Cause Analysis</li>
          <li>• Recovery Planning</li>
        </ul>
      </div>

      <!-- Security Consulting -->
      <div class="bg-gray-800/70 border border-gray-700 rounded-xl p-6 hover:bg-gray-800/90 transition-colors">
        <h2 class="text-xl font-semibold text-blue-300 mb-3">Security Consulting</h2>
        <p class="text-sm text-gray-300 mb-4">
          Strategic guidance on cybersecurity best practices, compliance requirements, and technology implementation. Align your security program with business objectives.
        </p>
        <ul class="text-xs text-gray-400 space-y-1">
          <li>• Security Strategy Development</li>
          <li>• Compliance Guidance</li>
          <li>• Technology Recommendations</li>
          <li>• Risk Assessment</li>
        </ul>
      </div>

      <!-- Cloud Security -->
      <div class="bg-gray-800/70 border border-gray-700 rounded-xl p-6 hover:bg-gray-800/90 transition-colors">
        <h2 class="text-xl font-semibold text-blue-300 mb-3">Cloud Security</h2>
        <p class="text-sm text-gray-300 mb-4">
          Secure your cloud infrastructure across AWS, Azure, and GCP. Implement proper configurations, access controls, and monitoring to protect cloud-native applications.
        </p>
        <ul class="text-xs text-gray-400 space-y-1">
          <li>• Cloud Configuration Review</li>
          <li>• Identity & Access Management</li>
          <li>• Data Protection</li>
          <li>• Compliance Automation</li>
        </ul>
      </div>

      <!-- Compliance Auditing -->
      <div class="bg-gray-800/70 border border-gray-700 rounded-xl p-6 hover:bg-gray-800/90 transition-colors">
        <h2 class="text-xl font-semibold text-blue-300 mb-3">Compliance Auditing</h2>
        <p class="text-sm text-gray-300 mb-4">
          Ensure adherence to industry standards and regulations including GDPR, HIPAA, PCI-DSS, and ISO 27001. Comprehensive audits with actionable remediation plans.
        </p>
        <ul class="text-xs text-gray-400 space-y-1">
          <li>• Regulatory Compliance</li>
          <li>• Gap Analysis</li>
          <li>• Audit Preparation</li>
          <li>• Documentation Review</li>
        </ul>
      </div>

      <!-- Security Training -->
      <div class="bg-gray-800/70 border border-gray-700 rounded-xl p-6 hover:bg-gray-800/90 transition-colors">
        <h2 class="text-xl font-semibold text-blue-300 mb-3">Security Training</h2>
        <p class="text-sm text-gray-300 mb-4">
          Empower your team with cybersecurity awareness and technical training. From phishing simulations to advanced security courses, keep your workforce vigilant.
        </p>
        <ul class="text-xs text-gray-400 space-y-1">
          <li>• Awareness Training</li>
          <li>• Technical Workshops</li>
          <li>• Phishing Simulations</li>
          <li>• Certification Preparation</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="bg-gray-950 border-t border-gray-800">
    <div class="max-w-6xl mx-auto px-4 py-16 text-center">
      <h2 class="text-2xl font-bold text-blue-400 mb-4">Ready to Secure Your Business?</h2>
      <p class="text-gray-300 mb-6 max-w-2xl mx-auto">
        Contact us today to discuss your cybersecurity needs and discover how we can protect your organization from emerging threats.
      </p>
      <a href="mailto:contact@cezenttech.com" class="inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors">
        Get Started
      </a>
    </div>
  </section>
</main>

</Layout>