---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    
    <style>
      /* Data Rain Canvas Styling */
      #dataRain {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        opacity: 0.4;
        pointer-events: none;
      }
      
      /* Hero Content Styling */
      .hero-content {
        position: relative;
        z-index: 10;
      }
    </style>
  </head>
  
  <body class="antialiased bg-[#020617] text-[#f8fafc] font-['Inter']">
    <Navigation />
    
    <!-- Add top padding to account for fixed navbar (h-16 = 64px) -->
    <main class="pt-16">
      <slot />
    </main>
    
    <Footer />
  </body>
</html>
